'qr_parked_carts', id, {\n        items: mergedItems,\n        total: mergedTotal\n      });\n    }\n\n    // ==================== File Upload (Signed URLs) ====================\n\n    async getUploadUrl(filename, contentType, folder = 'uploads') {\n      return this.request(`/api/public/${APP_ID}/upload-url`, {\n        method: 'POST',\n        body: JSON.stringify({\n          filename,\n          content_type: contentType,\n          folder\n        })\n      });\n    }\n    async uploadFile(uri, filename) {\n      // Get content type\n      const ext = filename.split('.').pop()?.toLowerCase() || '';\n      const contentTypes = {\n        jpg: 'image/jpeg',\n        jpeg: 'image/jpeg',\n        png: 'image/png',\n        gif: 'image/gif',\n        webp: 'image/webp'\n      };\n      const contentType = contentTypes[ext] || 'application/octet-stream';\n\n      // Get presigned URL\n      const {\n        upload_url,\n        file_url,\n        headers\n      } = await this.getUploadUrl(filename, contentType);\n\n      // Upload file\n      const response = await fetch(uri);\n      const blob = await response.blob();\n      const uploadResponse = await fetch(upload_url, {\n        method: 'PUT',\n        headers,\n        body: blob\n      });\n      if (!uploadResponse.ok) {\n        throw new Error('Upload failed');\n      }\n      return file_url;\n    }\n\n    // ==================== WebSocket Realtime ====================\n\n    connectRealtime(collections, onEvent) {\n      const ws = new WebSocket(`wss://commhub.cloud/api/ws/realtime?token=${this.token}&app_id=${APP_ID}`);\n      ws.onopen = () => {\n        console.log('[CommHub WS] Connected');\n        ws.send(JSON.stringify({\n          action: 'subscribe',\n          collections\n        }));\n      };\n      ws.onmessage = event => {\n        try {\n          const msg = JSON.parse(event.data);\n          if (msg.type === 'document_changed' || msg.type === 'change') {\n            onEvent(msg);\n          }\n        } catch (e) {\n          // Ignore parse errors\n        }\n      };\n      ws.onerror = error => {\n        console.error('[CommHub WS] Error:', error);\n      };\n\n      // Heartbeat\n      const heartbeat = setInterval(() => {\n        if (ws.readyState === WebSocket.OPEN) {\n          ws.send(JSON.stringify({\n            action: 'ping'\n          }));\n        }\n      }, 30000);\n      ws.onclose = () => {\n        console.log('[CommHub WS] Disconnected');\n        clearInterval(heartbeat);\n      };\n      return ws;\n    }\n\n    // ==================== Legacy Backend Fetch (DISABLED - Backend removed) ====================\n\n    /**\n     * Legacy fetch method - returns error since backend is removed\n     * Features like pair-display need to be migrated to CommHub\n     */\n    async fetch(path, options = {}) {\n      throw new Error('Denna funktion är inte tillgänglig. Backend har tagits bort.');\n    }\n  }\n\n  // ==================== Singleton Export ====================\n\n  const commhub = new CommHubService();\n\n  // Legacy compatibility - export as api too\n  const api = commhub;\n});","lineCount":1070,"map":[[12,2,1179,0,"Object"],[12,8,1179,0],[12,9,1179,0,"defineProperty"],[12,23,1179,0],[12,24,1179,0,"exports"],[12,31,1179,0],[13,4,1179,0,"enumerable"],[13,14,1179,0],[14,4,1179,0,"get"],[14,7,1179,0],[14,18,1179,0,"get"],[14,19,1179,0],[15,6,1179,0],[15,13,1179,0,"commhub"],[15,20,1179,0],[16,4,1179,0],[17,2,1179,0],[18,2,1182,0,"Object"],[18,8,1182,0],[18,9,1182,0,"defineProperty"],[18,23,1182,0],[18,24,1182,0,"exports"],[18,31,1182,0],[19,4,1182,0,"enumerable"],[19,14,1182,0],[20,4,1182,0,"get"],[20,7,1182,0],[20,18,1182,0,"get"],[20,19,1182,0],[21,6,1182,0],[21,13,1182,0,"api"],[21,16,1182,0],[22,4,1182,0],[23,2,1182,0],[24,2,1182,27],[24,6,1182,27,"_expoVirtualEnv"],[24,21,1182,27],[24,24,1182,27,"require"],[24,31,1182,27],[24,32,1182,27,"_dependencyMap"],[24,46,1182,27],[25,2,9,0],[25,6,9,0,"_reactNativeAsyncStorageAsyncSt