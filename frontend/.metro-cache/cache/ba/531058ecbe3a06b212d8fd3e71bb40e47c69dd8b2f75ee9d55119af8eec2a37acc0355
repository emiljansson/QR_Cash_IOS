ite email with new credentials\n      await this.sendInviteEmail(user.email, user.name || `${user.first_name || ''} ${user.last_name || ''}`.trim(), newCode, orgName);\n    }\n  }\n\n  // ==================== Singleton Export ====================\n\n  const commhub = new CommHubService();\n\n  // Legacy compatibility - export as api too\n  const api = commhub;\n});","lineCount":1743,"map":[[6,2,1,0],[7,0,2,0],[8,0,3,0],[9,0,4,0],[10,0,5,0],[11,0,6,0],[12,0,7,0],[13,2,1,0,"Object"],[13,8,1,0],[13,9,1,0,"defineProperty"],[13,23,1,0],[13,24,1,0,"exports"],[13,31,1,0],[14,4,1,0,"value"],[14,9,1,0],[15,2,1,0],[16,2,1,0],[16,11,1,0,"_interopDefault"],[16,27,1,0,"e"],[16,28,1,0],[17,4,1,0],[17,11,1,0,"e"],[17,12,1,0],[17,16,1,0,"e"],[17,17,1,0],[17,18,1,0,"__esModule"],[17,28,1,0],[17,31,1,0,"e"],[17,32,1,0],[18,6,1,0,"default"],[18,13,1,0],[18,15,1,0,"e"],[19,4,1,0],[20,2,1,0],[21,2,1871,0,"Object"],[21,8,1871,0],[21,9,1871,0,"defineProperty"],[21,23,1871,0],[21,24,1871,0,"exports"],[21,31,1871,0],[22,4,1871,0,"enumerable"],[22,14,1871,0],[23,4,1871,0,"get"],[23,7,1871,0],[23,18,1871,0,"get"],[23,19,1871,0],[24,6,1871,0],[24,13,1871,0,"commhub"],[24,20,1871,0],[25,4,1871,0],[26,2,1871,0],[27,2,1874,0,"Object"],[27,8,1874,0],[27,9,1874,0,"defineProperty"],[27,23,1874,0],[27,24,1874,0,"exports"],[27,31,1874,0],[28,4,1874,0,"enumerable"],[28,14,1874,0],[29,4,1874,0,"get"],[29,7,1874,0],[29,18,1874,0,"get"],[29,19,1874,0],[30,6,1874,0],[30,13,1874,0,"api"],[30,16,1874,0],[31,4,1874,0],[32,2,1874,0],[33,2,1874,27],[33,6,1874,27,"_babelRuntimeHelpersObjectWithoutPropertiesLoose"],[33,54,1874,27],[33,57,1874,27,"require"],[33,64,1874,27],[33,65,1874,27,"_dependencyMap"],[33,79,1874,27],[34,2,1874,27],[34,6,1874,27,"_objectWithoutPropertiesLoose"],[34,35,1874,27],[34,38,1874,27,"_interopDefault"],[34,53,1874,27],[34,54,1874,27,"_babelRuntimeHelpersObjectWithoutPropertiesLoose"],[34,102,1874,27],[35,2,1874,27],[35,6,1874,27,"_expoVirtualEnv"],[35,21,1874,27],[35,24,1874,27,"requir