us: 200,\n        created_at: {\n          $gte: startDate.toISOString()\n        }\n      });\n      const total = orders.reduce((sum, order) => sum + order.total, 0);\n      const count = orders.length;\n      return {\n        total,\n        count,\n        average: count > 0 ? total / count : 0,\n        orders\n      };\n    }\n\n    // ==================== Settings ====================\n\n    async getSettings() {\n      const settings = await this.list('qr_settings', {\n        limit: 1\n      });\n      return settings[0] || {};\n    }\n    async updateSettings(data) {\n      const existing = await this.getSettings();\n      if (existing.id) {\n        return this.update('qr_settings', existing.id, data);\n      } else {\n        return this.create('qr_settings', data);\n      }\n    }\n    async verifyPin(pin) {\n      const settings = await this.getSettings();\n      return settings.admin_pin === pin;\n    }\n\n    // ==================== Parked Carts ====================\n\n    async getParkedCarts() {\n      return this.list('qr_parked_carts');\n    }\n    async createParkedCart(data) {\n      return this.create('qr_parked_carts', Object.assign({}, data, {\n        created_at: new Date().toISOString()\n      }));\n    }\n    async deleteParkedCart(id) {\n      return this.delete('qr_parked_carts', id);\n    }\n    async mergeParkedCart(id, additionalItems, additionalTotal) {\n      const cart = await this.get('qr_parked_carts', id);\n      const mergedItems = [...cart.items, ...additionalItems];\n      const mergedTotal = cart.total + additionalTotal;\n      return this.update('qr_parked_carts', id, {\n        items: mergedItems,\n        total: mergedTotal\n      });\n    }\n\n    // ==================== File Upload (Signed URLs) ====================\n\n    async getUploadUrl(filename, contentType, folder = 'uploads') {\n      return this.request(`/api/public/${APP_ID}/upload-url`, {\n        method: 'POST',\n        body: JSON.stringify({\n          f