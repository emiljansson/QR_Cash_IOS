rn (data.documents || []).map(doc => Object.assign({\n        id: doc.id\n      }, doc.data));\n    }\n    async get(collection, id) {\n      const doc = await this.request(`/api/data/${collection}/${id}?app_id=${APP_ID}`);\n      // Extract data from nested structure\n      return Object.assign({\n        id: doc.id\n      }, doc.data);\n    }\n    async create(collection, data) {\n      const doc = await this.request(`/api/data/${collection}?app_id=${APP_ID}`, {\n        method: 'POST',\n        body: JSON.stringify({\n          data\n        })\n      });\n      return Object.assign({\n        id: doc.id\n      }, doc.data);\n    }\n    async update(collection, id, data) {\n      const doc = await this.request(`/api/data/${collection}/${id}?app_id=${APP_ID}`, {\n        method: 'PUT',\n        body: JSON.stringify({\n          data\n        })\n      });\n      return Object.assign({\n        id: doc.id\n      }, doc.data);\n    }\n    async delete(collection, id) {\n      await this.request(`/api/data/${collection}/${id}?app_id=${APP_ID}`, {\n        method: 'DELETE'\n      });\n    }\n    async query(collection, filter, options) {\n      const data = await this.request(`/api/data/${collection}/query?app_id=${APP_ID}`, {\n        method: 'POST',\n        body: JSON.stringify(Object.assign({\n          filter\n        }, options))\n      });\n      // CommHub returns documents with nested 'data' field - extract it\n      return (data.documents || []).map(doc => Object.assign({\n        id: doc.id\n      }, doc.data));\n    }\n\n    // ==================== Products ====================\n\n    async getProducts(activeOnly = false) {\n      if (activeOnly) {\n        return this.query('qr_products', {\n          active: {\n            $ne: false\n          }\n        }, {\n          sort: {\n            sort_order: 1\n          }\n        });\n      }\n      const products = await this.list('qr_products');\n      return products.sort((a, b) => (a.sort_order || 0) - 