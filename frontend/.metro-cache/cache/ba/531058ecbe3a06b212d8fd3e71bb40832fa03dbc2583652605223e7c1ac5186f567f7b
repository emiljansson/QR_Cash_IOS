ta) {\n      const existing = await this.getSettings();\n      if (existing.id) {\n        return this.update('qr_settings', existing.id, data);\n      } else {\n        return this.create('qr_settings', data);\n      }\n    }\n    async verifyPin(pin) {\n      const settings = await this.getSettings();\n      return settings.admin_pin === pin;\n    }\n\n    // ==================== Parked Carts ====================\n\n    async getParkedCarts() {\n      return this.list('qr_parked_carts');\n    }\n    async createParkedCart(data) {\n      return this.create('qr_parked_carts', Object.assign({}, data, {\n        created_at: new Date().toISOString()\n      }));\n    }\n    async deleteParkedCart(id) {\n      return this.delete('qr_parked_carts', id);\n    }\n    async mergeParkedCart(id, additionalItems, additionalTotal) {\n      const cart = await this.get('qr_parked_carts', id);\n      const mergedItems = [...cart.items, ...additionalItems];\n      const mergedTotal = cart.total + additionalTotal;\n      return this.update('qr_parked_carts', id, {\n        items: mergedItems,\n        total: mergedTotal\n      });\n    }\n\n    // ==================== File Upload (Signed URLs) ====================\n\n    async getUploadUrl(filename, contentType, folder = 'uploads') {\n      return this.request(`/api/public/${APP_ID}/upload-url`, {\n        method: 'POST',\n        body: JSON.stringify({\n          filename,\n          content_type: contentType,\n          folder\n        })\n      });\n    }\n    async uploadFile(uri, filename) {\n      // Get content type\n      const ext = filename.split('.').pop()?.toLowerCase() || '';\n      const contentTypes = {\n        jpg: 'image/jpeg',\n        jpeg: 'image/jpeg',\n        png: 'image/png',\n        gif: 'image/gif',\n        webp: 'image/webp'\n      };\n      const contentType = contentTypes[ext] || 'application/octet-stream';\n\n      // Get presigned URL\n      const {\n        upload_url,\n        file_url,\n        he