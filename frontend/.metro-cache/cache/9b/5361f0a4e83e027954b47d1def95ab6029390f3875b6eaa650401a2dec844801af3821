it AsyncStorage.default.getItem(TOKEN_KEY);\n        const userData = await AsyncStorage.default.getItem(USER_KEY);\n        if (userData) {\n          const user = JSON.parse(userData);\n          this.userId = user.user_id;\n        }\n      } catch (e) {\n        // Silently ignore - this can happen during SSR\n      }\n    }\n    async saveToken(token, user) {\n      this.token = token;\n      this.userId = user.user_id;\n      await AsyncStorage.default.setItem(TOKEN_KEY, token);\n      await AsyncStorage.default.setItem(USER_KEY, JSON.stringify(user));\n    }\n    async clearToken() {\n      this.token = null;\n      this.userId = null;\n      await AsyncStorage.default.removeItem(TOKEN_KEY);\n      await AsyncStorage.default.removeItem(USER_KEY);\n    }\n    getToken() {\n      return this.token;\n    }\n    setToken(token) {\n      this.token = token;\n    }\n    getUserId() {\n      return this.userId;\n    }\n    isAuthenticated() {\n      return !!this.token;\n    }\n\n    // ==================== Auth using qr_users collection (User Sync) ====================\n\n    /**\n     * Login using qr_users collection directly\n     * This syncs with existing user data instead of CommHub's separate auth system\n     */\n    async login(email, password) {\n      console.log('[CommHub] Login attempt for:', email);\n\n      // Query qr_users collection to find user by email\n      const response = await fetch(`${COMMHUB_URL}/api/data/qr_users/query?app_id=${APP_ID}`, {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          'X-API-Key': API_KEY\n        },\n        body: JSON.stringify({\n          filter: {\n            email: email.toLowerCase()\n          },\n          limit: 1\n        })\n      });\n      if (!response.ok) {\n        console.log('[CommHub] Query failed:', response.status);\n        throw new Error('Kunde inte ansluta till servern');\n      }\n      const data = await response.json();\n      console.