\n    }\n    async loginWithToken(token) {\n      this.token = token;\n      await AsyncStorage.default.setItem(TOKEN_KEY, token);\n      return this.getMe();\n    }\n    async logout() {\n      try {\n        if (this.token) {\n          await fetch(`${COMMHUB_URL}/api/public/${APP_ID}/logout`, {\n            method: 'POST',\n            headers: {\n              'Authorization': `Bearer ${this.token}`\n            }\n          });\n        }\n      } catch (e) {\n        // Ignore logout errors\n      }\n      await this.clearToken();\n    }\n    async getMe() {\n      const response = await fetch(`${COMMHUB_URL}/api/public/${APP_ID}/me`, {\n        headers: {\n          'Authorization': `Bearer ${this.token}`\n        }\n      });\n      if (!response.ok) {\n        if (response.status === 401) {\n          await this.clearToken();\n          throw new Error('Session expired');\n        }\n        throw new Error('Failed to get user profile');\n      }\n      const user = await response.json();\n      this.userId = user.user_id;\n      await AsyncStorage.default.setItem(USER_KEY, JSON.stringify(user));\n      return user;\n    }\n    async updateProfile(data) {\n      const response = await fetch(`${COMMHUB_URL}/api/public/${APP_ID}/me`, {\n        method: 'PUT',\n        headers: {\n          'Authorization': `Bearer ${this.token}`,\n          'Content-Type': 'application/json'\n        },\n        body: JSON.stringify(data)\n      });\n      if (!response.ok) {\n        throw new Error('Failed to update profile');\n      }\n      return response.json();\n    }\n\n    // ==================== Generic Data Operations (with RLS) ====================\n\n    async request(path, options = {}) {\n      if (!this.token) {\n        throw new Error('Not authenticated');\n      }\n      const response = await fetch(`${COMMHUB_URL}${path}`, {\n        ...options,\n        headers: {\n          'Authorization': `Bearer ${this.token}`,\n          'Content-Type': 'application/json',\n          ...options.headers\n        }\n      });\n      if (!response.ok) {\n        if (response.status === 401) {\n          await this.clearToken();\n          throw new Error('Session expired');\n        }\n        const error = await response.json().catch(() => ({\n          detail: 'Request failed'\n        }));\n        throw new Error(error.detail || `HTTP ${response.status}`);\n      }\n      return response.json();\n    }\n    async list(collection, options) {\n      const params = new URLSearchParams({\n        app_id: APP_ID\n      });\n      if (options?.limit) params.set('limit', String(options.limit));\n      if (options?.skip) params.set('skip', String(options.skip));\n      const data = await this.request(`/api/data/${collection}?${params.toString()}`);\n      // CommHub returns documents with nested 'data' field - extract it\n      return (data.documents || []).map(doc => ({\n        id: doc.id,\n        ...doc.data\n      }));\n    }\n    async get(collection, id) {\n      const doc = await this.request(`/api/data/${collection}/${id}?app_id=${APP_ID}`);\n      // Extract data from nested structure\n      return {\n        id: doc.id,\n        ...doc.data\n      };\n    }\n    async create(collection, data) {\n      const doc = await this.request(`/api/data/${collection}?app_id=${APP_ID}`, {\n        method: 'POST',\n        body: JSON.stringify({\n          data\n        })\n      });\n      return {\n        id: doc.id,\n        ...doc.data\n      };\n    }\n    async update(collection, id, data) {\n      const doc = await this.request(`/api/data/${collection}/${id}?app_id=${APP_ID}`, {\n        method: 'PUT',\n        body: JSON.stringify({\n          data\n        })\n      });\n      return {\n        id: doc.id,\n        ...doc.data\n      };\n    }\n    async delete(collection, id) {\n      await this.request(`/api/data/${collection}/${id}?app_id=${APP_ID}`, {\n        method: 'DELETE'\n      });\n    }\n    async query(collection, filter, options) {\n      const data = await this.request(`/api/data/${collection}/query?app_id=${APP_ID}`, {\n        method: 'POST',\n        body: JSON.stringify({\n          filter,\n          ...options\n        })\n      });\n      // CommHub returns documents with nested 'data' field - extract it\n      return (data.documents || []).map(doc => ({\n        id: doc.id,\n        ...doc.data\n      }));\n    }\n\n    // ==================== Products ====================\n\n    async getProducts(activeOnly = false) {\n      // CRITICAL: Filter by user_id to only show user's own products\n      const userId = await this.getUserIdAsync();\n      if (!userId) {\n        console.warn('[CommHub] No user_id available for product filtering');\n        return [];\n      }\n      if (activeOnly) {\n        return this.query('qr_products', {\n          user_id: userId,\n          active: {\n            $ne: false\n          }\n        }, {\n          sort: {\n            sort_order: 1\n          }\n        });\n      }\n      const products = await this.query('qr_products', {\n        user_id: userId\n      });\n      return products.sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));\n    }\n    async createProduct(data) {\n      // Include user_id when creating products\n      const userId = await this.getUserIdAsync();\n      return this.create('qr_products', {\n        ...data,\n        active: true,\n        user_id: userId\n      });\n    }\n    async updateProduct(id, data) {\n      return this.update('qr_products', id, data);\n    }\n    async deleteProduct(id) {\n      return this.delete('qr_products', id);\n    }\n    async reorderProducts(productIds) {\n      // Update sort_order for each product\n      await Promise.all(productIds.map((id, index) => this.update('qr_products', id, {\n        sort_order: index\n      })));\n    }\n\n    // ==================== Orders ====================\n\n    async getOrders(status, limit = 50) {\n      // CRITICAL: Filter by user_id to only show user's own orders\n      const userId = await this.getUserIdAsync();\n      if (!userId) {\n        console.warn('[CommHub] No user_id available for order filtering');\n        return [];\n      }\n      if (status !== undefined) {\n        return this.query('qr_orders', {\n          user_id: userId,\n          status\n        }, {\n          sort: {\n            created_at: -1\n          },\n          limit\n        });\n      }\n      return this.query('qr_orders', {\n        user_id: userId\n      }, {\n        sort: {\n          created_at: -1\n        },\n        limit\n      });\n    }\n    async createOrder(data) {\n      const userId = await this.getUserIdAsync();\n      return this.create('qr_orders', {\n        ...data,\n        user_id: userId,\n        created_at: new Date().toISOString()\n      });\n    }\n    async confirmOrder(orderId) {\n      return this.update('qr_orders', orderId, {\n        status: 200\n      });\n    }\n    async cancelOrder(orderId) {\n      return this.update('qr_orders', orderId, {\n        status: 400\n      });\n    }\n    async deleteOrder(orderId) {\n      return this.delete('qr_orders', orderId);\n    }\n    async getDailyStats(period = 'day', date) {\n      // Calculate stats locally from orders\n      const userId = await this.getUserIdAsync();\n      if (!userId) {\n        console.warn('[CommHub] No user_id available for daily stats');\n        return {\n          total: 0,\n          count: 0,\n          average: 0,\n          orders: []\n        };\n      }\n      const now = new Date();\n      const startDate = new Date();\n      if (period === 'day') {\n        startDate.setHours(0, 0, 0, 0);\n      } else if (period === 'week') {\n        startDate.setDate(now.getDate() - 7);\n      } else if (period === 'month') {\n        startDate.setMonth(now.getMonth() - 1);\n      }\n      const orders = await this.query('qr_orders', {\n        user_id: userId,\n        status: 200,\n        crea