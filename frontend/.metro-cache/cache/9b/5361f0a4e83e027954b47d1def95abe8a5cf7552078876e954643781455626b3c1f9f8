it AsyncStorage.default.getItem(TOKEN_KEY);\n        const userData = await AsyncStorage.default.getItem(USER_KEY);\n        if (userData) {\n          const user = JSON.parse(userData);\n          this.userId = user.user_id;\n        }\n      } catch (e) {\n        // Silently ignore - this can happen during SSR\n      }\n    }\n    async saveToken(token, user) {\n      this.token = token;\n      this.userId = user.user_id;\n      await AsyncStorage.default.setItem(TOKEN_KEY, token);\n      await AsyncStorage.default.setItem(USER_KEY, JSON.stringify(user));\n    }\n    async clearToken() {\n      this.token = null;\n      this.userId = null;\n      await AsyncStorage.default.removeItem(TOKEN_KEY);\n      await AsyncStorage.default.removeItem(USER_KEY);\n    }\n    getToken() {\n      return this.token;\n    }\n    setToken(token) {\n      this.token = token;\n    }\n    getUserId() {\n      return this.userId;\n    }\n    isAuthenticated() {\n      return !!this.token;\n    }\n\n    // ==================== Auth using qr_users collection (User Sync) ====================\n\n    /**\n     * Login using qr_users collection directly\n     * This syncs with existing user data instead of CommHub's separate auth system\n     */\n    async login(email, password) {\n      // Query qr_users collection to find user by email\n      const response = await fetch(`${COMMHUB_URL}/api/data/qr_users/query?app_id=${APP_ID}`, {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          'X-API-Key': API_KEY\n        },\n        body: JSON.stringify({\n          filter: {\n            email: email.toLowerCase()\n          },\n          limit: 1\n        })\n      });\n      if (!response.ok) {\n        throw new Error('Kunde inte ansluta till servern');\n      }\n      const data = await response.json();\n      const users = data.documents || [];\n      if (users.length === 0) {\n        throw new Error('Fel e-post eller lösenord');\n      }\n      const user = users[0];\n\n      // Verify password using bcrypt comparison via CommHub or simple check\n      // Note: For security, password verification should ideally be done server-side\n      // This is a simplified version - in production, use CommHub's auth or a backend\n      const isValidPassword = await this.verifyPassword(password, user.password_hash || user.password);\n      if (!isValidPassword) {\n        throw new Error('Fel e-post eller lösenord');\n      }\n\n      // Create a session token (simple JWT-like structure)\n      const sessionToken = this.generateSessionToken(user);\n\n      // Build user profile\n      const userProfile = {\n        user_id: user.id || user._id,\n        email: user.email,\n        name: user.name || user.organization_name,\n        organization_name: user.organization_name,\n        phone: user.phone,\n        picture: user.picture,\n        email_verified: user.email_verified ?? true,\n        subscription_active: user.subscription_active ?? true,\n        role: user.role,\n        org_id: user.org_id || user.id\n      };\n      await this.saveToken(sessionToken, userProfile);\n      return {\n        token: sessionToken,\n        user_id: userProfile.user_id,\n        email: userProfile.email,\n        org_id: userProfile.org_id,\n        expires_at: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString(),\n        user: userProfile\n      };\n    }\n\n    /**\n     * Login with code (for sub-users)\n     */\n    async loginWithCode(code) {\n      // Query qr_org_users collection to find user by login code\n      const response = await fetch(`${COMMHUB_URL}/api/data/qr_org_users/query?app_id=${APP_ID}`, {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          'X-API-Key': API_KEY\n        },\n        body: JSON.stringify({\n          filter: {\n            login_code: code\n          },\n          limit: 1\n        })\n      });\n      if (!response.ok) {\n        throw new Error('Kunde inte ansluta till servern');\n      }\n      const data = await response.json();\n      const users = data.documents || [];\n      if (users.length === 0) {\n        throw new Error('Ogiltig inloggningskod');\n      }\n      const orgUser = users[0];\n\n      // Get the parent user for org info\n      const parentResponse = await fetch(`${COMMHUB_URL}/api/data/qr_users/${orgUser.parent_user_id}?app_id=${APP_ID}`, {\n        headers: {\n          'Content-Type': 'application/json',\n          'X-API-Key': API_KEY\n        }\n      });\n      let parentUser = null;\n      if (parentResponse.ok) {\n        parentUser = await parentResponse.json();\n      }\n\n      // Create session token\n      const sessionToken = this.generateSessionToken({\n        ...orgUser,\n        parent_user: parentUser\n      });\n\n      // Build user profile for sub-user\n      const userProfile = {\n        user_id: orgUser.parent_user_id,\n        // Use parent's user_id for data access\n        email: orgUser.email || `${code}@org.local`,\n        name: orgUser.name,\n        organization_name: parentUser?.organization_name || '',\n        phone: orgUser.phone,\n        role: orgUser.role || 'staff',\n        org_id: orgUser.parent_user_id\n      };\n      await this.saveToken(sessionToken, userProfile);\n      return {\n        token: sessionToken,\n        user_id: userProfile.user_id,\n        email: userProfile.email,\n        org_id: userProfile.org_id,\n        expires_at: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString(),\n        user: userProfile\n      };\n    }\n\n    /**\n     * Simple password verification\n     * Note: bcrypt comparison would require a server-side call\n     */\n    async verifyPassword(inputPassword, storedHash) {\n      // If no hash stored, check plain text (legacy)\n      if (!storedHash) return false;\n\n      // Check if it's a bcrypt hash\n      if (storedHash.startsWith('$2')) {\n        // For bcrypt, we need