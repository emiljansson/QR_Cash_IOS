    const error = await response.json().catch(() => ({\n          detail: 'Request failed'\n        }));\n        throw new Error(error.detail || `HTTP ${response.status}`);\n      }\n      return response.json();\n    }\n    async list(collection, options) {\n      const params = new URLSearchParams({\n        app_id: APP_ID\n      });\n      if (options?.limit) params.set('limit', String(options.limit));\n      if (options?.skip) params.set('skip', String(options.skip));\n      const data = await this.request(`/api/data/${collection}?${params.toString()}`);\n      return data.documents || [];\n    }\n    async get(collection, id) {\n      return this.request(`/api/data/${collection}/${id}?app_id=${APP_ID}`);\n    }\n    async create(collection, data) {\n      return this.request(`/api/data/${collection}?app_id=${APP_ID}`, {\n        method: 'POST',\n        body: JSON.stringify({\n          data\n        })\n      });\n    }\n    async update(collection, id, data) {\n      return this.request(`/api/data/${collection}/${id}?app_id=${APP_ID}`, {\n        method: 'PUT',\n        body: JSON.stringify({\n          data\n        })\n      });\n    }\n    async delete(collection, id) {\n      await this.request(`/api/data/${collection}/${id}?app_id=${APP_ID}`, {\n        method: 'DELETE'\n      });\n    }\n    async query(collection, filter, options) {\n      const data = await this.request(`/api/data/${collection}/query?app_id=${APP_ID}`, {\n        method: 'POST',\n        body: JSON.stringify({\n          filter,\n          ...options\n        })\n      });\n      return data.documents || [];\n    }\n\n    // ==================== Products ====================\n\n    async getProducts(activeOnly = false) {\n      if (activeOnly) {\n        return this.query('qr_products', {\n          active: {\n            $ne: false\n          }\n        }, {\n          sort: {\n            sort_order: 1\n          }\n        });\n      }\n      const products = await this.list('qr_products');\n      return products.sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));\n    }\n    async createProduct(data) {\n      return this.create('qr_products', {\n        ...data,\n        active: true\n      });\n    }\n    async updateProduct(id, data) {\n      return this.update('qr_products', id, data);\n    }\n    async deleteProduct(id) {\n      return this.delete('qr_products', id);\n    }\n    async reorderProducts(productIds) {\n      // Update sort_order for each product\n      await Promise.all(productIds.map((id, index) => this.update('qr_products', id, {\n        sort_order: index\n      })));\n    }\n\n    // ==================== Orders ====================\n\n    async getOrders(status, limit = 50) {\n      if (status !== undefined) {\n        return this.query('qr_orders', {\n          status\n        }, {\n          sort: {\n            created_at: -1\n          },\n          limit\n        });\n      }\n      return this.query('qr_orders', {}, {\n        sort: {\n          created_at: -1\n        },\n        limit\n      });\n    }\n    async createOrder(data) {\n      return this.create('qr_orders', {\n        ...data,\n        created_at: new Date().toISOString()\n      });\n    }\n    async confirmOrder(orderId) {\n      return this.update('qr_orders', orderId, {\n        status: 200\n      });\n    }\n    async cancelOrder(orderId) {\n      return this.update('qr_orders', orderId, {\n        status: 400\n      });\n    }\n    async deleteOrder(orderId) {\n      return this.delete('qr_orders', orderId);\n    }\n    async getDailyStats(period = 'day', date) {\n      // Calculate stats locally from orders\n      const now = new Date();\n      const startDate = new Date();\n      if (period === 'day') {\n        startDate.setHours(0, 0, 0, 0);\n      } else if (period === 'week') {\n        startDate.setDate(now.getDate() - 7);\n      } else if (period === 'month') {\n        startDate.setMonth(now.getMonth() - 1);\n      }\n      const orders = await this.query('qr_orders', {\n        status: 200,\n        created_at: {\n          $gte: startDate.toISOString()\n        }\n      });\n      const total = orders.reduce((sum, order) => sum + order.total, 0);\n      const count = orders.length;\n      return {\n        total,\n        count,\n        average: count > 0 ? total / count : 0,\n        orders\n      };\n    }\n\n    // ==================== Settings ====================\n\n    async getSettings() {\n      const settings = await this.list('qr_settings', {\n        limit: 1\n      });\n      return settings[0] || {};\n    }\n    async updateSettings(data) {\n      const existing = await this.getSettings();\n      if (existing.id) {\n        return this.update('qr_settings', existing.id, data);\n      } else {\n        return this.create('qr_settings', data);\n      }\n    }\n    async verifyPin(pin) {\n      const settings = await this.getSettings();\n      return settings.admin_pin === pin;\n    }\n\n    // ==================== Parked Carts ====================\n\n    async getParkedCarts() {\n      return this.list('qr_parked_carts');\n    }\n    async createParkedCart(data) {\n      return this.create('qr_parked_carts', {\n        ...data,\n        created_at: new Date().toISOString()\n      });\n    }\n    async deleteParkedCart(id) {\n      return this.delete('qr_parked_carts', id);\n    }\n    async mergeParkedCart(id, additionalItems, additionalTotal) {\n      const cart = await this.get('qr_parked_carts', id);\n      const mergedItems = [...cart.items, ...additionalItems];\n      const mergedTotal = cart.total + additionalTotal;\n      return this.update('qr_parked_carts', id, {\n        items: mergedItems,\n        total: mergedTotal\n      });\n    }\n\n    // ==================== File Upload (Signed URLs) ====================\n\n    async getUploadUrl(filename, contentType, folder = 'uploads') {\n      return this.request(`/api/public/${APP_ID}/upload-url`, {\n        method: 'P