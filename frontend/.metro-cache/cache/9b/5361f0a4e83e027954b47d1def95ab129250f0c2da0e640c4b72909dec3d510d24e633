ew Date().toISOString()\n      });\n      return newPassword;\n    }\n\n    /**\n     * Send credentials to a sub-user (regenerates both code and password)\n     */\n    async sendSubUserCredentials(subUserId) {\n      const users = await this.query('qr_org_users', {\n        user_id: subUserId\n      }, {\n        limit: 1\n      });\n      if (users.length === 0) {\n        throw new Error('Användaren hittades inte');\n      }\n      const user = users[0];\n      const newCode = this.generateLoginCode();\n      const newPassword = this.generatePassword();\n\n      // Update user with new credentials\n      await this.update('qr_org_users', user._doc_id || user.id, {\n        login_code: newCode,\n        password: newPassword,\n        updated_at: new Date().toISOString()\n      });\n\n      // Get org name\n      const currentUser = await AsyncStorage.default.getItem(USER_KEY);\n      let orgName = '';\n      if (currentUser) {\n        const userData = JSON.parse(currentUser);\n        orgName = userData.organization_name || '';\n      }\n\n      // Send invite email with new credentials\n      await this.sendInviteEmail(user.email, user.name || `${user.first_name || ''} ${user.last_name || ''}`.trim(), newCode, orgName);\n    }\n  }\n\n  // ==================== Singleton Export ====================\n\n  const commhub = new CommHubService();\n\n  // Legacy compatibility - export as api too\n  const api = commhub;\n});","lineCount":2009,"map":[[12,2,2126,0,"Object"],[12,8,2126,0],[12,9,2126,0,"defineProperty"],[12,23,2126,0],[12,24,2126,0,"exports"],[12,31,2126,0],[13,4,2126,0,"enumerable"],[13,14,2126,0],[14,4,2126,0,"get"],[14,7,2126,0],[14,18,2126,0,"get"],[14,19,2126,0],[15,6,2126,0],[15,13,2126,0,"commhub"],[15,20,2126,0],[16,4,2126,0],[17,2,2126,0],[18,2,2129,0,"Object"],[18,8,2129,0],[18,9,2129,0,"defineProperty"],[18,23,2129,0],[18,24,2129,0,"exports"],[18,31,2129,0],[19,4,2129,0,"enumerable"],[19,14,2129,0],[20,4,2129,0,"get"],[20,7,2129,0],[20,18,2129,0